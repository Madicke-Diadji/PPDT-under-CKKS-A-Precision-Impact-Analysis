FROM ubuntu:22.04

ARG DEBIAN_FRONTEND=noninteractive
ARG SEAL_TAG=v4.1.2
ARG SEAL_BUILD_JOBS=2

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    cmake \
    git \
    libssl-dev \
    pkg-config \
    python3 \
    python3-pip \
    zlib1g-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt

RUN git clone --depth 1 --branch ${SEAL_TAG} https://github.com/microsoft/SEAL.git

WORKDIR /opt/SEAL/build

RUN cmake .. \
    -DCMAKE_BUILD_TYPE=Release \
    -DSEAL_BUILD_DEPS=ON \
    -DSEAL_USE_MSGSL=OFF \
    -DSEAL_USE_ZLIB=ON \
    -DSEAL_BUILD_EXAMPLES=OFF \
    -DSEAL_BUILD_TESTS=OFF \
    -DSEAL_BUILD_BENCH=OFF \
    -DBUILD_SHARED_LIBS=ON \
    -DCMAKE_INSTALL_PREFIX=/opt/seal-install \
    && cmake --build . --target install --parallel ${SEAL_BUILD_JOBS}

ENV SEAL_ROOT=/opt/seal-install
ENV SEAL_DIR=/opt/seal-install/lib/cmake/SEAL
ENV LD_LIBRARY_PATH=/opt/seal-install/lib:/opt/seal-install/lib64:${LD_LIBRARY_PATH}

WORKDIR /workspace

CMD ["bash"]
